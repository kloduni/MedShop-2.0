@model AllProductsQueryModel

@{
    ViewBag.Title = "All Products";
    var previousPage = Model.CurrentPage - 1;
    if (previousPage < 1) { previousPage = 1; }

    var maxPage = Math.Ceiling((double)Model.TotalProductsCount / Model.ProductsPerPage);
    var shouldButtonBeDisabled = Model.CurrentPage == (int)maxPage || !Model.Products.Any();
}

<div class="py-8 max-w-7xl mx-auto">
    <div class="mb-8 text-center md:text-left">
        <h1 class="text-4xl font-black text-white tracking-tight flex items-center justify-center md:justify-start gap-3">
            <i class="bi bi-shop text-blue-500"></i> @ViewBag.Title
        </h1>
        <p class="mt-2 text-lg text-slate-400">Browse our complete catalog of high-grade medical supplies.</p>
    </div>

    <form id="filter-form" method="get" class="mb-10 bg-slate-900 border border-slate-700/50 rounded-2xl p-6 shadow-xl relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-blue-600 to-emerald-500 opacity-50"></div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 items-end relative z-10">
            
            <div>
                <label asp-for="Category" class="block text-sm font-bold text-slate-300 mb-2"></label>
                <div class="relative">
                    <select asp-for="Category" class="w-full bg-slate-800 border border-slate-600 hover:border-blue-500/50 hover:bg-slate-700/50 text-white rounded-xl appearance-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 py-3 px-4 pr-10 transition-all outline-none cursor-pointer">
                        <option value="">All Categories</option>
                        @foreach (var category in Model.Categories)
                        {
                            <option value="@category">@category</option>
                        }
                    </select>
                    <i class="bi bi-chevron-down absolute right-4 top-1/2 transform -translate-y-1/2 text-slate-400 pointer-events-none"></i>
                </div>
            </div>

            <div>
                <label asp-for="SearchTerm" class="block text-sm font-bold text-slate-300 mb-2">Search</label>
                <div class="relative group">
                    <i class="bi bi-search absolute left-4 top-1/2 transform -translate-y-1/2 text-slate-400 group-focus-within:text-blue-500 transition-colors"></i>
                    <input asp-for="SearchTerm" placeholder="Search by name..." class="w-full bg-slate-800 border border-slate-600 hover:border-blue-500/50 hover:bg-slate-700/50 text-white rounded-xl focus:ring-2 focus:ring-blue-500 focus:border-blue-500 py-3 pl-11 pr-4 transition-all outline-none" />
                </div>
            </div>

            <div>
                <label asp-for="Sorting" class="block text-sm font-bold text-slate-300 mb-2"></label>
                <div class="relative">
                    <select asp-for="Sorting" class="w-full bg-slate-800 border border-slate-600 hover:border-blue-500/50 hover:bg-slate-700/50 text-white rounded-xl appearance-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 py-3 px-4 pr-10 transition-all outline-none cursor-pointer">
                        <option value="0">Newest Arrivals</option>
                        <option value="1">Lowest Price</option>
                    </select>
                    <i class="bi bi-chevron-down absolute right-4 top-1/2 transform -translate-y-1/2 text-slate-400 pointer-events-none"></i>
                </div>
            </div>

            <div>
                <label asp-for="ProductsPerPage" class="block text-sm font-bold text-slate-300 mb-2">Per Page</label>
                <div class="relative">
                    <select asp-for="ProductsPerPage" class="w-full bg-slate-800 border border-slate-600 hover:border-blue-500/50 hover:bg-slate-700/50 text-white rounded-xl appearance-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 py-3 px-4 pr-10 transition-all outline-none cursor-pointer">
                        <option value="4">4 Items</option>
                        <option value="6">6 Items (Best for Tablets)</option>
                        <option value="9">9 Items (Default)</option>
                        <option value="12">12 Items</option>
                        <option value="16">16 Items</option>
                    </select>
                    <i class="bi bi-chevron-down absolute right-4 top-1/2 transform -translate-y-1/2 text-slate-400 pointer-events-none"></i>
                </div>
            </div>

        </div>
    </form>

    <div id="product-grid-container">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-10">
            @if (!Model.Products.Any())
            {
                <div class="col-span-full py-16 text-center bg-slate-900 rounded-2xl border border-slate-700/50 shadow-lg">
                    <div class="w-24 h-24 bg-slate-800 text-slate-500 rounded-full flex items-center justify-center mx-auto mb-6">
                        <i class="bi bi-search text-4xl"></i>
                    </div>
                    <h3 class="text-2xl font-bold text-white">No products found</h3>
                    <p class="text-slate-400 mt-2 text-lg">We couldn't find anything matching your current filters.</p>
                    <a asp-action="All" asp-route-searchTerm="" asp-route-category="" class="inline-block mt-6 text-blue-400 hover:text-blue-300 font-medium transition-colors">
                        Clear all filters
                    </a>
                </div>
            }
            else
            {
                @foreach (var product in Model.Products)
                {
                    <partial name="_ProductPartial" model="product" />
                }
            }
        </div>

        <div class="mt-12 flex flex-col sm:flex-row justify-between items-center border-t border-slate-800 pt-8 gap-4">
            <a asp-controller="Product" asp-action="All"
                   asp-route-currentPage="@previousPage"
                   asp-route-category="@Model.Category"
                   asp-route-searchTerm="@Model.SearchTerm"
                   asp-route-sorting="@((int)Model.Sorting)"
                   asp-route-productsPerPage="@Model.ProductsPerPage"
                   class="inline-flex justify-center items-center w-full sm:w-auto px-6 py-3 border border-slate-600 text-sm font-bold rounded-xl text-slate-300 bg-slate-800 hover:bg-slate-700 hover:text-white hover:-translate-y-1 hover:shadow-lg transition-all @(Model.CurrentPage == 1 ? "opacity-40 pointer-events-none" : "")">
                <i class="bi bi-chevron-left mr-2"></i> Previous Page
            </a>

            <div class="px-6 py-2 bg-slate-900 border border-slate-700 rounded-lg text-sm text-slate-400 font-medium">
                Page <span class="text-white font-bold mx-1">@Model.CurrentPage</span> of <span class="text-white font-bold mx-1">@(maxPage == 0 ? 1 : maxPage)</span>
            </div>

            <a asp-controller="Product" asp-action="All"
                   asp-route-currentPage="@(Model.CurrentPage + 1)"
                   asp-route-category="@Model.Category"
                   asp-route-searchTerm="@Model.SearchTerm"
                   asp-route-sorting="@((int)Model.Sorting)"
                   asp-route-productsPerPage="@Model.ProductsPerPage"
                   class="inline-flex justify-center items-center w-full sm:w-auto px-6 py-3 border border-slate-600 text-sm font-bold rounded-xl text-slate-300 bg-slate-800 hover:bg-slate-700 hover:text-white hover:-translate-y-1 hover:shadow-lg transition-all @(shouldButtonBeDisabled ? "opacity-40 pointer-events-none" : "")">
                Next Page <i class="bi bi-chevron-right ml-2"></i>
            </a>
        </div>
    </div>
</div>