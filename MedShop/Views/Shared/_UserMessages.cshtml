@using MedShop.Core.Constants

<script>
    $(function () {
        toastr.options = {
            "positionClass": "toast-bottom-right",
            "progressBar": true,
            "preventDuplicates": true,
            "showDuration": "300",
            "hideDuration": "1000",
            "timeOut": "5000",
            "extendedTimeOut": "1000"
        };

        @if (TempData[MessageConstants.ErrorMessage] != null)
        {
                @:toastr.error('@TempData[MessageConstants.ErrorMessage].ToString()');
        }

        @if (TempData[MessageConstants.WarningMessage] != null)
        {
                @:toastr.warning('@TempData[MessageConstants.WarningMessage].ToString()');
        }

        @if (TempData[MessageConstants.SuccessMessage] != null)
        {
                @:toastr.success('@TempData[MessageConstants.SuccessMessage].ToString()');
        }
    });
</script>