@model int;

@if (Model > 0)
{
    <li>
        <a asp-controller="ShoppingCart" asp-action="ShoppingCart" class="flex items-center gap-2 text-white hover:text-gray-200 transition-colors">
            <i class="bi bi-cart4 text-xl"></i>
            <span class="bg-red-500 text-white text-xs font-bold px-2 py-1 rounded-full">@Model</span>
        </a>
    </li>
}