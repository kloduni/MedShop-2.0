@model IEnumerable<MedShop.Core.Models.Product.ProductServiceModel>

@{
    ViewBag.Title = "My Products";
}

<h2 class="text-center capitalize text-blue-600 font-serif text-3xl font-bold mb-4">@ViewBag.Title</h2>
<hr class="border-gray-300 mb-6" />

@if (Model.Any())
{
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        @foreach (var product in Model)
        {
            <partial name="_ProductPartial" model="@product" />
        }
    </div>
}
else
{
    <h3 class="text-center text-2xl text-gray-600 font-semibold mt-10">You have no products yet!</h3>
}