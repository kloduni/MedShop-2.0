<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MedShop</title>
    <link rel="stylesheet" href="~/lib/toastr/toastr.min.css" />
    <link rel="stylesheet" href="~/css/tailwind.output.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.2/font/bootstrap-icons.css">
</head>
<body class="bg-gray-50 text-gray-900 min-h-screen flex flex-col">
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <partial name="_UserMessages" />

    <header class="bg-blue-600 text-white shadow-md">
        <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex items-center justify-between h-16">
                
                <div class="flex-shrink-0">
                    <a class="flex items-center gap-2 text-xl font-bold tracking-tight" asp-controller="Home" asp-action="Index">
                        <img src="https://content.presentermedia.com/files/clipart/00001000/1783/blue_medical_symbol_pc_800_wht.jpg" alt="Logo" class="w-8 h-8 rounded-full bg-white p-1">
                        MedShop
                    </a>
                </div>

                <div class="hidden md:block">
                    <ul class="flex items-center space-x-6">
                        
                        <li class="relative">
                            <details class="group">
                                <summary class="flex items-center gap-1 cursor-pointer hover:text-blue-200 py-2 list-none font-medium">
                                    Product
                                    <svg class="w-4 h-4 transition group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                                </summary>
                                <div class="absolute left-0 mt-2 w-48 bg-white rounded-md shadow-lg py-1 z-50 text-gray-700">
                                    <a class="block px-4 py-2 text-sm hover:bg-gray-100 hover:text-blue-600" asp-controller="Product" asp-action="All">
                                        <i class="bi bi-shop mr-2"></i> All Products
                                    </a>
                                    @if (User?.Identity?.IsAuthenticated ?? false)
                                    {
                                        <a class="block px-4 py-2 text-sm hover:bg-gray-100 hover:text-blue-600" asp-controller="Product" asp-action="MyProducts">
                                            <i class="bi bi-safe2 mr-2"></i> My Products
                                        </a>
                                        <a class="block px-4 py-2 text-sm hover:bg-gray-100 hover:text-blue-600" asp-controller="Product" asp-action="Add">
                                            <i class="bi bi-cash-coin mr-2"></i> Add Product
                                        </a>
                                    }
                                </div>
                            </details>
                        </li>

                        @if (User?.Identity?.IsAuthenticated ?? false)
                        {
                            <li>
                                <a class="hover:text-blue-200 font-medium transition-colors" asp-controller="Order" asp-action="All">Completed Orders</a>
                            </li>
                        }
                    </ul>
                </div>

                <div class="hidden md:flex items-center space-x-6">
                    <ul class="flex items-center">
                        @await Component.InvokeAsync("ShoppingCartSummary")
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <div class="flex-grow w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="bg-white border-t border-gray-200 mt-auto py-6">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-gray-500 text-sm">
            &copy; @DateTime.Now.Year MedShop - <span id="time"></span>
            <script>
                            setInterval(myTimer, 1000);
                            function myTimer() {
                                const d = new Date();
                                document.getElementById("time").innerHTML = d.toLocaleTimeString();
                            }
            </script>
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/lib/toastr/toastr.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>