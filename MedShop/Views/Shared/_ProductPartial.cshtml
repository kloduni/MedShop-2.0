@using System.Security.Claims
@using static MedShop.Core.Constants.User.AdminConstants
@model ProductServiceModel

@{
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var isOwnerOrAdmin = User.Identity?.IsAuthenticated == true && (Model.SellerId == currentUserId || User.IsInRole(AdminRoleName));
}

<div class="group bg-slate-900 rounded-2xl shadow-xl overflow-hidden flex flex-col h-full border border-slate-700/50 transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_10px_20px_rgba(0,0,0,0.4)] hover:border-blue-500/30 relative">
    
    <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-transparent via-blue-500 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 z-10"></div>

    <div class="aspect-[4/3] p-6 bg-slate-950/50 relative overflow-hidden flex items-center justify-center">
        <img class="max-h-40 object-contain transition-transform duration-500 group-hover:scale-110 drop-shadow-lg" src="@Model.ImageUrl" alt="@Model.ProductName">
        <div class="absolute top-3 left-3 px-3 py-1 bg-blue-600/20 text-blue-400 text-[10px] font-bold uppercase tracking-widest rounded-full border border-blue-600/30 backdrop-blur-sm z-20">
            @Model.Category
        </div>
    </div>
    
    <div class="p-5 flex-grow bg-slate-900 border-t border-slate-800 flex flex-col justify-between relative z-20">
        <div>
            <h3 class="text-lg font-black text-white capitalize truncate mb-1 group-hover:text-blue-400 transition-colors">@Model.ProductName</h3>
            <p class="text-xs text-slate-500 flex items-center gap-1 mb-4">
                <i class="bi bi-person text-blue-500"></i> @Model.Seller
            </p>
            
            <div class="flex justify-between items-center mb-6">
                <span class="text-2xl font-black text-emerald-400 drop-shadow-[0_0_10px_rgba(52,211,153,0.2)]">$@Model.Price.ToString("F2")</span>
                <span class="text-[10px] text-slate-500 font-bold uppercase tracking-widest bg-slate-800 px-2 py-1 rounded-md border border-slate-700">Qty: @Model.Quantity</span>
            </div>
        </div>
        
        <div class="space-y-3 mt-auto">
            <div class="flex gap-2">
                <a asp-controller="Product" asp-action="Details" asp-route-id="@Model.Id" asp-route-information="@Model.GetInformation()"
                       class="flex-1 flex justify-center items-center gap-2 py-2.5 bg-slate-800 hover:bg-slate-700 text-slate-300 hover:text-white text-xs font-bold rounded-lg transition-all duration-200 active:scale-95 border border-slate-600 hover:border-slate-500 hover:-translate-y-1 hover:shadow-[0_0_15px_rgba(148,163,184,0.3)]">
                    <i class="bi bi-eye-fill"></i> View
                </a>
                
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-controller="ShoppingCart" asp-action="AddItemToShoppingCart" asp-route-id="@Model.Id"
                           class="flex-[1.5] flex justify-center items-center gap-2 py-2.5 bg-blue-600 hover:bg-blue-500 text-white text-xs font-bold rounded-lg transition-all duration-200 active:scale-95 shadow-[0_0_15px_rgba(37,99,235,0.4)] hover:shadow-[0_0_25px_rgba(37,99,235,0.6)] hover:-translate-y-1">
                        <i class="bi bi-cart-plus-fill text-sm"></i> Add
                    </a>
                }
            </div>

            @if (isOwnerOrAdmin)
            {
                <div class="flex gap-2 pt-3 mt-3 border-t border-slate-800/80">
                    <a asp-area="" asp-controller="Product" asp-action="Edit" asp-route-id="@Model.Id" asp-route-information="@Model.GetInformation()"
                           class="flex-1 text-center py-2 bg-amber-600/10 text-amber-500 border border-amber-600/30 hover:bg-amber-600 hover:text-white font-bold rounded-lg text-xs transition-all duration-200 active:scale-95 hover:-translate-y-1 hover:shadow-[0_0_15px_rgba(245,158,11,0.4)]">
                        <i class="bi bi-pencil-square"></i> Edit
                    </a>
                    
                    <a asp-area="" asp-controller="Product" asp-action="Delete" asp-route-id="@Model.Id" asp-route-information="@Model.GetInformation()"
                           class="flex-1 text-center py-2 bg-red-600/10 text-red-500 border border-red-600/30 hover:bg-red-600 hover:text-white font-bold rounded-lg text-xs transition-all duration-200 active:scale-95 hover:-translate-y-1 hover:shadow-[0_0_15px_rgba(239,68,68,0.5)]">
                        <i class="bi bi-trash-fill"></i> Delete
                    </a>
                </div>
            }
        </div>
    </div>
</div>