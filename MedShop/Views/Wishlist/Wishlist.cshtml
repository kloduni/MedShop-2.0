@model IEnumerable<MedShop.Core.Models.Product.ProductServiceModel>

<div class="container mx-auto px-4 py-8">
    <div class="flex items-center gap-3 mb-8">
        <h1 class="text-3xl font-black text-slate-100 tracking-tight">
            My Wishlist
        </h1>
        <i class="bi bi-heart-fill text-pink-500 text-2xl animate-pulse"></i>
    </div>

    @if (!Model.Any())
    {
        <div class="bg-slate-900 rounded-2xl border border-slate-700/60 p-12 text-center shadow-xl">
            <div class="w-20 h-20 bg-slate-800 rounded-full flex items-center justify-center mx-auto mb-6">
                <i class="bi bi-heart text-4xl text-slate-500"></i>
            </div>
            <h2 class="text-2xl font-bold text-slate-200 mb-2">Your wishlist is empty</h2>
            <p class="text-slate-400 mb-8 max-w-md mx-auto">Looks like you haven't added any medical supplies to your wishlist yet.</p>
            
            <a asp-controller="Product" asp-action="All"
                   class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-500 text-white px-8 py-3.5 rounded-xl font-bold transition-all shadow-[0_4px_15px_rgba(37,99,235,0.3)] hover:-translate-y-1">
                <i class="bi bi-search"></i> Browse Products
            </a>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
            @foreach (var product in Model)
            {
                <div id="wishlist-card-@product.Id" class="transition-all duration-300 h-full">
                    
                    <partial name="_ProductPartial" model="product" />
                    
                </div>
            }
        </div>
    }
</div>