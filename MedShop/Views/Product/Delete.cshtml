@model ProductServiceModel
@using static MedShop.Core.Constants.User.AdminConstants

@{
    ViewBag.Title = "Delete Product";
}

<div class="max-w-5xl mx-auto py-12 px-4 sm:px-6 lg:px-8 relative">
    
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full h-full max-w-3xl bg-red-600/5 rounded-[100%] blur-[100px] pointer-events-none z-0"></div>

    <div class="text-center mb-12 relative z-10">
        <h2 class="text-5xl font-black text-white tracking-tight uppercase drop-shadow-md">Confirm Deletion</h2>
        <p class="text-red-400 mt-4 text-lg flex items-center justify-center gap-2 font-bold bg-red-950/30 inline-flex px-6 py-2 rounded-full border border-red-900/50 backdrop-blur-sm">
            <i class="bi bi-exclamation-triangle-fill text-xl"></i>
            This action is permanent and cannot be reversed.
        </p>
    </div>

    <div class="flex flex-col lg:flex-row gap-8 items-stretch relative z-10">
        <div class="lg:w-2/5 w-full shrink-0 flex">
            <div class="relative overflow-hidden rounded-[2rem] border border-slate-700/50 bg-slate-900/80 backdrop-blur-xl p-8 shadow-2xl flex-grow flex items-center justify-center">
                <img class="w-full h-auto max-h-[400px] object-contain drop-shadow-2xl transition-transform hover:scale-105 duration-500" src="@Model.ImageUrl" alt="@Model.ProductName">
            </div>
        </div>
        
        <div class="lg:w-3/5 w-full bg-slate-900/80 backdrop-blur-xl p-8 md:p-10 rounded-[2rem] shadow-2xl border border-slate-700/50 flex flex-col justify-between">
            <form method="post" asp-route-information="@Model.GetInformation()" class="h-full flex flex-col">
                <input type="hidden" asp-for="@Model.Id" />
                
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 flex-grow">
                    <div class="sm:col-span-2">
                        <label class="block text-[10px] font-black uppercase tracking-widest text-slate-500 mb-2">Product Name</label>
                        <div class="w-full px-5 py-4 bg-slate-950/50 border border-slate-800 rounded-xl text-slate-200 font-bold text-lg">@Model.ProductName</div>
                    </div>

                    <div>
                        <label class="block text-[10px] font-black uppercase tracking-widest text-slate-500 mb-2">Category</label>
                        <div class="w-full px-5 py-4 bg-slate-950/50 border border-slate-800 rounded-xl text-slate-300 font-medium">@Model.Category</div>
                    </div>

                    <div>
                        <label class="block text-[10px] font-black uppercase tracking-widest text-slate-500 mb-2">Price</label>
                        <div class="w-full px-5 py-4 bg-slate-950/50 border border-slate-800 rounded-xl text-emerald-400 font-black text-xl">$@Model.Price.ToString("F2")</div>
                    </div>

                    <div class="sm:col-span-2">
                        <label class="block text-[10px] font-black uppercase tracking-widest text-slate-500 mb-2">Description</label>
                        <div class="w-full px-5 py-4 bg-slate-950/50 border border-slate-800 rounded-xl text-slate-400 italic text-sm leading-relaxed">@Model.Description</div>
                    </div>

                    <div class="sm:col-span-2">
                        <label class="block text-[10px] font-black uppercase tracking-widest text-slate-500 mb-2">Seller</label>
                        <div class="w-full px-5 py-4 bg-slate-950/50 border border-slate-800 rounded-xl text-slate-300 flex items-center gap-3 font-medium">
                            <i class="bi bi-shield-check text-blue-500"></i> @Model.Seller
                        </div>
                    </div>
                </div>
                
                <div class="flex flex-col sm:flex-row gap-4 pt-8 mt-8 border-t border-slate-800/80">
                    <a asp-action="All" class="flex-1 flex justify-center items-center px-6 py-5 bg-slate-800 hover:bg-slate-700 text-white font-bold rounded-xl transition-all active:scale-95 border border-slate-600 hover:border-slate-500">
                        Cancel Request
                    </a>
                    <button type="submit" class="flex-1 flex justify-center items-center gap-2 px-6 py-5 bg-red-600 hover:bg-red-500 text-white font-black rounded-xl shadow-[0_0_20px_rgba(220,38,38,0.4)] hover:shadow-[0_0_30px_rgba(220,38,38,0.6)] hover:-translate-y-1 transition-all duration-200 active:scale-95 uppercase tracking-widest text-sm">
                        <i class="bi bi-trash-fill text-lg"></i> Confirm Delete
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>