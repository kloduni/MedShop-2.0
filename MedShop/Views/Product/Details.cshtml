@model MedShop.Core.Models.Product.ProductServiceModel

@{
    ViewBag.Title = "Product Details";
}

<h2 class="text-center capitalize text-blue-600 font-serif text-3xl font-bold mb-4">@ViewBag.Title</h2>
<hr class="border-gray-300 mb-6" />

<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row gap-8 bg-white shadow-lg rounded-xl p-6">
        
        <div class="md:w-1/3 flex-shrink-0">
            <img class="w-full h-auto object-cover rounded-lg border border-gray-200 shadow-sm" src="@Model.ImageUrl" alt="Product Image">
        </div>

        <div class="md:w-2/3 font-mono text-gray-800">
            <div class="bg-gray-100 rounded-lg border border-gray-200 overflow-hidden">
                <div class="bg-gray-200 px-6 py-4 border-b border-gray-300">
                    <h3 class="text-2xl capitalize font-bold text-gray-900">@Model.ProductName</h3>
                </div>
                
                <div class="p-6 space-y-4">
                    <p class="text-base leading-relaxed">@Model.Description</p>
                    <p class="text-base">Category: <span class="font-bold text-gray-900">@Model.Category</span></p>
                    <p class="text-base">Quantity: <span class="font-bold text-gray-900">@Model.Quantity</span></p>
                    <p class="text-base">Seller: <span class="font-bold text-gray-900">@Model.Seller</span></p>
                    <p class="text-xl mt-4">Price: <span class="font-bold text-green-600">$@String.Format("{0:f2}", Model.Price)</span></p>
                </div>

                @if (this.User?.Identity?.IsAuthenticated ?? false)
                {
                    <div class="px-6 pb-6">
                        <details class="bg-white border border-gray-300 rounded-lg shadow-sm group">
                            <summary class="px-4 py-3 font-semibold cursor-pointer hover:bg-gray-50 text-gray-800 list-none flex justify-between items-center rounded-lg">
                                <span>Actions</span>
                                <span class="transition group-open:rotate-180">
                                    <svg fill="none" height="24" shape-rendering="geometricPrecision" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="24"><path d="M6 9l6 6 6-6"></path></svg>
                                </span>
                            </summary>
                            <div class="px-4 py-4 border-t border-gray-300 flex flex-wrap gap-4">
                                <a class="inline-flex items-center gap-2 px-4 py-2 bg-yellow-500 hover:bg-yellow-600 text-white font-medium rounded-md transition-colors shadow-sm"
                                       asp-controller="Product" asp-action="Edit" asp-route-id="@Model.Id" asp-route-information="@Model.GetInformation()">
                                    <i class="bi bi-pencil-fill"></i> Edit
                                </a>
                                <a class="inline-flex items-center gap-2 px-4 py-2 bg-red-600 hover:bg-red-700 text-white font-medium rounded-md transition-colors shadow-sm"
                                       asp-controller="Product" asp-action="Delete" asp-route-id="@Model.Id" asp-route-information="@Model.GetInformation()">
                                    <i class="bi bi-trash-fill"></i> Delete
                                </a>
                            </div>
                        </details>
                    </div>
                }
            </div>
        </div>
        
    </div>
</div>