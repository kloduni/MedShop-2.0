@using System.Security.Claims
@using static MedShop.Core.Constants.User.AdminConstants
@model ProductServiceModel

@{
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var isAdmin = User.IsInRole(AdminRoleName);
    var isOwner = Model.SellerId == currentUserId;
    var isOwnerOrAdmin = User.Identity?.IsAuthenticated == true && (isOwner || isAdmin);
    
    var isMyProductsPage = ViewData["IsMyProducts"] as bool? == true;
    var showVisibilityToggle = isAdmin || (isOwner && isMyProductsPage);
    var removeOnHide = !isMyProductsPage ? "true" : "false";
}

<div class="group bg-slate-900 rounded-2xl border border-slate-700/60 overflow-hidden flex flex-col h-full hover:shadow-2xl hover:-translate-y-1 hover:border-blue-500/40 transition-all duration-300 relative">
    
    <a asp-controller="Product" asp-action="Details" asp-route-id="@Model.Id" asp-route-information="@Model.GetInformation()" class="absolute inset-0 z-10" aria-label="View details for @Model.ProductName"></a>

    <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-slate-600 to-blue-500 opacity-0 group-hover:opacity-100 transition-opacity duration-500 z-0"></div>

    <div class="relative h-72 w-full bg-slate-800/40 p-4 flex items-center justify-center overflow-hidden border-b border-slate-800">
        <img src="@Model.ImageUrl" alt="@Model.ProductName"
             class="w-full h-full object-contain transition-transform duration-500 group-hover:scale-105 drop-shadow-md" />
        
        <span class="absolute top-4 left-4 px-3 py-1 bg-slate-900/95 backdrop-blur-sm text-slate-300 text-[11px] font-semibold tracking-wider uppercase rounded-md border border-slate-700/80 shadow-sm z-20">
            @Model.Category
        </span>

        @if (User.Identity?.IsAuthenticated == true && !isOwner)
        {
            <button data-id="@Model.Id" title="Quick Add to Cart"
                    class="add-to-cart-btn absolute top-4 right-4 z-20 h-12 w-12 bg-slate-900/80 backdrop-blur-md hover:bg-blue-600 text-slate-300 hover:text-white rounded-full flex items-center justify-center border border-slate-700/80 shadow-lg transition-all duration-200 hover:scale-110 active:scale-95">
                <i class="bi bi-cart-plus text-xl"></i>
            </button>
        }
    </div>
    
    <div class="flex flex-col flex-grow p-6">
        
        <div class="mb-4">
            <div class="text-xs text-slate-400 mb-2 font-medium flex items-center gap-1.5">
                <i class="bi bi-person-badge text-blue-500"></i> @Model.Seller
            </div>
            <h3 class="text-2xl font-bold text-slate-100 leading-snug group-hover:text-blue-400 transition-colors line-clamp-2">
                @Model.ProductName
            </h3>
        </div>
        
        <div class="mt-auto space-y-4 z-20">
            
            <div class="flex flex-col pt-4 border-t border-slate-800/50">
                <div class="flex items-center gap-2 mb-3">
                    <div class="flex text-amber-400 text-[10px] drop-shadow-[0_0_2px_rgba(251,191,36,0.3)] gap-[2px]">
                        @for (int i = 1; i <= 5; i++)
                        {
                            if (i <= Math.Round(Model.AverageRating))
                            {
                                <i class="bi bi-star-fill"></i>
                            }
                            else
                            {
                                <i class="bi bi-star text-slate-700"></i>
                            }
                        }
                    </div>
                    <span class="text-slate-500 text-[9px] font-black uppercase tracking-widest">
                        @(Model.AverageRating > 0 ? Model.AverageRating.ToString("F1") : "New")
                    </span>
                </div>

                <div class="flex items-end justify-between">
                    <div class="flex flex-col">
                        <span class="text-[10px] text-slate-500 font-bold uppercase tracking-widest mb-1">Price</span>
                        
                        <div class="flex items-baseline text-white">
                            <span class="text-xl font-bold text-slate-400 mr-1">€</span>
                            <span class="text-3xl font-black tracking-tight">@Model.Price.ToString("0.00")</span>
                        </div>
                    </div>
                    
                    <div class="mb-1">
                        @if (Model.Quantity > 0)
                        {
                            <span class="inline-flex items-center gap-1.5 px-3 py-2 bg-blue-500/10 text-blue-400 border border-blue-500/20 rounded-xl text-sm font-bold">
                                <i class="bi bi-box-seam"></i> @Model.Quantity in stock
                            </span>
                        }
                        else
                        {
                            <span class="inline-flex items-center gap-1.5 px-3 py-2 bg-red-500/10 text-red-400 border border-red-500/20 rounded-xl text-sm font-bold">
                                <i class="bi bi-x-circle"></i> Out of stock
                            </span>
                        }
                    </div>
                </div>
            </div>

            @if (!isOwner)
            {
                <div class="flex flex-col gap-2 relative z-30">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <button data-id="@Model.Id"
                                class="buy-now-btn w-full flex justify-center items-center gap-2 py-3.5 bg-blue-600 hover:bg-blue-500 text-white text-sm font-bold rounded-xl transition-all duration-200 active:scale-95 shadow-[0_4px_15px_rgba(37,99,235,0.3)]">
                            <i class="bi bi-bag-check-fill text-lg"></i> Buy Now
                        </button>
                        
                        <button data-id="@Model.Id"
                                class="wishlist-btn w-full flex justify-center items-center gap-2 py-2.5 bg-slate-800 hover:bg-slate-700 text-slate-300 hover:text-pink-400 text-sm font-bold rounded-xl border border-slate-700 transition-all duration-200 active:scale-95">
    
                            @if (Model.IsInWishlist)
                            {
                                <i class="bi bi-heart-fill text-pink-500 text-base transition-colors duration-300"></i>
                            }
                            else
                            {
                                <i class="bi bi-heart text-base transition-colors duration-300"></i>
                            }
                            <span>Wishlist</span>
                        </button>
                    }
                    else
                    {
                        <a asp-area="" asp-controller="User" asp-action="Login"
                               class="w-full flex justify-center items-center gap-2 py-3.5 bg-slate-800 hover:bg-slate-700 text-slate-300 hover:text-white text-sm font-bold rounded-xl border border-slate-700 transition-all duration-200 active:scale-95">
                            <i class="bi bi-lock-fill"></i> Sign in to buy
                        </a>
                    }
                </div>
            }

            @if (isOwnerOrAdmin)
            {
                <div class="flex flex-col gap-3 pt-4 border-t border-slate-800">
                    @if (showVisibilityToggle)
                    {
                        <button type="button"
                                data-remove-on-hide="@removeOnHide"
                                onclick="toggleProductVisibility(event, @Model.Id, this)"
                                class="w-full flex justify-between items-center px-4 py-2.5 bg-slate-800/80 hover:bg-slate-700 text-slate-300 font-bold rounded-xl text-xs uppercase tracking-widest transition-all">
                            <span>Storefront Visibility</span>
                            @if (Model.IsVisible)
                            {
                                <span class="status-badge px-3 py-1 bg-emerald-500/10 text-emerald-400 rounded-lg border border-emerald-500/20 font-black">Visible</span>
                            }
                            else
                            {
                                <span class="status-badge px-3 py-1 bg-slate-700 text-slate-400 rounded-lg border border-slate-600 font-black">Hidden</span>
                            }
                        </button>
                    }

                    <div class="flex gap-3">
                        <a asp-area="" asp-controller="Product" asp-action="Edit" asp-route-id="@Model.Id" asp-route-information="@Model.GetInformation()"
                               class="flex-1 flex justify-center items-center gap-2 py-2.5 bg-slate-700/50 hover:bg-slate-600 text-slate-200 font-bold rounded-xl text-xs uppercase tracking-widest transition-all">
                            <i class="bi bi-pencil-square"></i> Edit
                        </a>
                        
                        <button type="button"
                                data-product-name="@Model.ProductName"
                                data-action-url="@Url.Action("Delete", "Product", new { id = Model.Id, information = Model.GetInformation() })"
                                onclick="triggerDeleteModal(this)"
                                class="flex-1 flex justify-center items-center gap-2 py-2.5 bg-red-500/10 hover:bg-red-600 hover:text-white text-red-400 font-bold rounded-xl border border-red-500/20 text-xs uppercase tracking-widest transition-all">
                            <i class="bi bi-trash"></i> Delete
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>
</div>