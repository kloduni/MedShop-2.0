@model ShoppingCartViewModel

@{
    ViewData["Title"] = "Shopping cart summary";
}

<div class="max-w-5xl mx-auto mt-10">
    <div class="text-center mb-8">
        <h2 class="text-3xl font-bold text-white flex items-center justify-center gap-3">
            <i class="bi bi-cart3 text-blue-500"></i> Your Cart
        </h2>
        <p class="text-slate-400 mt-2">Review your items before proceeding to checkout.</p>
    </div>

    <div class="bg-slate-900 rounded-2xl shadow-xl border border-slate-700/50 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-800">
                <thead class="bg-slate-900/50">
                    <tr>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-slate-400 uppercase tracking-wider">Product</th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-slate-400 uppercase tracking-wider">Price</th>
                        <th scope="col" class="px-6 py-4 text-center text-xs font-bold text-slate-400 uppercase tracking-wider">Quantity</th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-slate-400 uppercase tracking-wider">Subtotal</th>
                        <th scope="col" class="px-6 py-4 relative"><span class="sr-only">Actions</span></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-800/50">
                    @foreach (var item in Model.ShoppingCart.ShoppingCartItems)
                    {
                        <tr id="cart-row-@item.Id" class="hover:bg-slate-800/20 transition-colors">
                            <td class="px-6 py-5 whitespace-nowrap text-sm font-medium text-white">
                                @item.Product.ProductName
                            </td>
                            <td class="px-6 py-5 whitespace-nowrap text-sm text-slate-300">
                                @item.Product.Price.ToString("c")
                            </td>
                            <td class="px-6 py-5 whitespace-nowrap text-sm text-slate-300 text-center">
                                <span id="qty-@item.Id" class="bg-slate-800 px-3 py-1 rounded-lg border border-slate-700 font-mono transition-all duration-300">
                                    @item.Amount
                                </span>
                            </td>
                            <td id="subtotal-@item.Id" class="px-6 py-5 whitespace-nowrap text-sm font-bold text-blue-400 transition-all duration-300">
                                @((item.Amount * item.Product.Price).ToString("c"))
                            </td>
                            <td class="px-6 py-5 whitespace-nowrap text-right text-sm font-medium">
                                <div class="flex items-center justify-end gap-4">
                                    <button class="cart-action-btn text-slate-400 hover:text-red-400 transition-colors hover:scale-110 disabled:opacity-50"
                                            data-action="remove" data-cartitem-id="@item.Id" title="Remove One">
                                        <i class="bi bi-dash-circle-fill text-xl pointer-events-none"></i>
                                    </button>
                                    <button class="cart-action-btn text-slate-400 hover:text-emerald-400 transition-colors hover:scale-110 disabled:opacity-50"
                                            data-action="add" data-product-id="@item.Product.Id" data-cartitem-id="@item.Id" title="Add One">
                                        <i class="bi bi-plus-circle-fill text-xl pointer-events-none"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
                <tfoot class="bg-slate-900/50 border-t border-slate-700">
                    <tr>
                        <td colspan="2" class="px-6 py-5"></td>
                        <td class="px-6 py-5 whitespace-nowrap text-sm font-bold text-slate-300 text-right uppercase tracking-wider">Total:</td>
                        <td id="grand-total-display" class="px-6 py-5 whitespace-nowrap text-lg font-black text-emerald-400 transition-all duration-300">
                            @Model.ShoppingCartTotal.ToString("c")
                        </td>
                        <td class="px-6 py-5"></td>
                    </tr>
                </tfoot>
            </table>
        </div>
        
        <div class="px-8 py-6 border-t border-slate-800 bg-slate-900 flex flex-wrap items-center justify-between gap-4">
            <div class="flex gap-3">
                <a class="px-5 py-2.5 bg-transparent border border-yellow-500/30 text-yellow-500 hover:bg-yellow-500/10 rounded-lg text-sm font-bold transition-all"
                       asp-controller="ShoppingCart" asp-action="ClearCart">
                    <i class="bi bi-trash3"></i> Clear Cart
                </a>
                <a class="px-5 py-2.5 bg-slate-800 hover:bg-slate-700 border border-slate-600 text-white rounded-lg text-sm font-bold transition-all shadow-sm"
                       asp-controller="Product" asp-action="All">
                    <i class="bi bi-arrow-left"></i> Continue Shopping
                </a>
            </div>

            <div class="flex items-center gap-4">
                <div id="paypal-btn" class="mt-1"></div>
                
                <a class="px-8 py-3 bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-bold rounded-xl transition-all active:scale-95 shadow-[0_0_15px_rgba(16,185,129,0.3)] hover:shadow-[0_0_20px_rgba(16,185,129,0.5)] flex items-center gap-2"
                       asp-controller="Order" asp-action="CompleteOrder">
                    Checkout <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://www.paypalobjects.com/api/checkout.js"></script>
    <script>
        let _total = @Html.Raw(Model.ShoppingCartTotal);

        document.querySelectorAll('.cart-action-btn').forEach(btn => {
        btn.addEventListener('click', async (e) => {
        e.preventDefault();
                
        const action = btn.getAttribute('data-action');
        const cartItemId = btn.getAttribute('data-cartitem-id');
        const productId = btn.getAttribute('data-product-id');
                
        btn.disabled = true;
                
        let url = action === 'add'
        ? `/ShoppingCart/AddItemJson?id=${productId}`
        : `/ShoppingCart/RemoveItemJson?id=${cartItemId}`;
                
        try {
        const res = await fetch(url, { method: 'POST' });
        const text = await res.text();
                    
        if (!res.ok) {
        console.error("Server Error:", text);
        toastr.error("An error occurred connecting to the server.", "Error");
        btn.disabled = false;
        return;
        }

        const data = JSON.parse(text);
                    
        if (data.success) {
        if (action === 'remove' && data.newAmount === 0) {
        document.getElementById(`cart-row-${cartItemId}`).remove();
        } else if (action === 'remove' || action === 'add') {
        const targetId = action === 'add' ? cartItemId || productId : cartItemId;
                            
        document.getElementById(`qty-${cartItemId}`).innerText = data.newAmount;
        document.getElementById(`subtotal-${cartItemId}`).innerText = data.subtotalFormatted;
                            
        document.getElementById(`qty-${cartItemId}`).classList.add('text-amber-400');
        setTimeout(() => document.getElementById(`qty-${cartItemId}`).classList.remove('text-amber-400'), 300);
        }
                        
        document.getElementById('grand-total-display').innerText = data.grandTotalFormatted;
                        
        const badge = document.getElementById('cart-badge-count');
        if (badge) {
        badge.innerText = data.cartCount;
        if (data.cartCount === 0) {
        badge.classList.add('hidden');
        window.location.reload();
        } else {
        badge.classList.remove('hidden');
        }
        }
                        
        _total = data.grandTotalRaw;
                        
        } else {
        toastr.warning(data.message || "Action could not be completed.", "Notice");
        }
        } catch (err) {
        console.error("Fetch error:", err);
        toastr.error("An error occurred. Check the console.", "Error");
        } finally {
        btn.disabled = false;
        }
        });
        });

        paypal.Button.render({
        env: 'sandbox',
        client: {
        sandbox: 'AcKRtgL4i68EZ2ZYuYUx3ilihAg2YhL5dtF_m19A8MjBWVOn6ewNS4M_uV8gA3xi98zTcUq38gUHbVFx'
        },
        locale: 'en_US',
        style: {
        size: 'small',
        color: 'gold',
        shape: 'pill'
        },
        commit: true,
        payment: function (data, actions) {
        return actions.payment.create({
        transactions: [{
        amount: {
        total: _total,
        currency: 'USD'
        }
        }]
        });
        },
        onAuthorize: function (data, actions) {
        return actions.payment.execute().then(function () {
        var url = '@Url.Action("CompleteOrder", "Order", new { })';
        window.location.href = url;
        });
        }
        }, '#paypal-btn')
    </script>
}