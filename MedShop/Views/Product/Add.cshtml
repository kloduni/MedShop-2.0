@model ProductBaseModel

@{
    ViewData["Title"] = "Add New Product";
}

<div class="max-w-3xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
    <div class="bg-slate-900/80 backdrop-blur-xl p-8 sm:p-12 rounded-[2rem] shadow-2xl border border-slate-700/50 relative overflow-hidden">
        
        <div class="absolute -top-24 -left-24 w-64 h-64 bg-blue-600/10 rounded-full blur-[80px] pointer-events-none"></div>

        <div class="text-center mb-10 relative z-10">
            <h2 class="text-4xl font-black text-white tracking-tight">@ViewData["Title"]</h2>
            <p class="text-slate-400 mt-3 text-lg">List a new medical product in the catalog.</p>
        </div>
        
        <form method="post" class="space-y-6 relative z-10">
            <div>
                <label asp-for="ProductName" class="block text-sm font-bold text-slate-300 mb-2 uppercase tracking-widest">Product Name</label>
                <input asp-for="ProductName" class="w-full px-5 py-3 bg-slate-800/50 hover:bg-slate-800 border border-slate-600 rounded-xl text-white placeholder-slate-500 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all" placeholder="e.g. Digital Sphygmomanometer">
                    <span asp-validation-for="ProductName" class="text-sm text-red-400 mt-2 block font-medium"></span>
                </div>
    
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label asp-for="Price" class="block text-sm font-bold text-slate-300 mb-2 uppercase tracking-widest"></label>
                        <div class="relative">
                            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 font-bold">$</span>
                            <input asp-for="Price" class="w-full pl-8 pr-5 py-3 bg-slate-800/50 hover:bg-slate-800 border border-slate-600 rounded-xl text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all" placeholder="0.00">
                            </div>
                            <span asp-validation-for="Price" class="text-sm text-red-400 mt-2 block font-medium"></span>
                        </div>
    
                        <div>
                            <label asp-for="Quantity" class="block text-sm font-bold text-slate-300 mb-2 uppercase tracking-widest"></label>
                            <input asp-for="Quantity" class="w-full px-5 py-3 bg-slate-800/50 hover:bg-slate-800 border border-slate-600 rounded-xl text-white focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all" placeholder="10">
                                <span asp-validation-for="Quantity" class="text-sm text-red-400 mt-2 block font-medium"></span>
                            </div>
                        </div>

                        <div>
                            <label asp-for="Description" class="block text-sm font-bold text-slate-300 mb-2 uppercase tracking-widest"></label>
                            <textarea asp-for="Description" rows="4" class="w-full px-5 py-3 bg-slate-800/50 hover:bg-slate-800 border border-slate-600 rounded-xl text-white placeholder-slate-500 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all resize-y" placeholder="Describe the product's medical use, specifications, and safety info..."></textarea>
                            <span asp-validation-for="Description" class="text-sm text-red-400 mt-2 block font-medium"></span>
                        </div>

                        <div>
                            <label asp-for="ImageUrl" class="block text-sm font-bold text-slate-300 mb-2 uppercase tracking-widest">Image URL</label>
                            <input asp-for="ImageUrl" class="w-full px-5 py-3 bg-slate-800/50 hover:bg-slate-800 border border-slate-600 rounded-xl text-white placeholder-slate-500 focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all" placeholder="https://example.com/product-image.jpg">
                                <span asp-validation-for="ImageUrl" class="text-sm text-red-400 mt-2 block font-medium"></span>
                            </div>

                            <div>
                                <label asp-for="CategoryId" class="block text-sm font-bold text-slate-300 mb-2 uppercase tracking-widest">Category</label>
                                <div class="relative">
                                    <select asp-for="CategoryId" class="w-full px-5 py-3 bg-slate-800/50 hover:bg-slate-800 border border-slate-600 rounded-xl text-white appearance-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-all cursor-pointer">
                                        <option value="" disabled selected>-- Select a Category --</option>
                                        @foreach (var category in Model.ProductCategories)
                                        {
                                            <option value="@category.Id">@category.Name</option>
                                        }
                                    </select>
                                    <i class="bi bi-chevron-down absolute right-4 top-1/2 transform -translate-y-1/2 text-slate-400 pointer-events-none"></i>
                                </div>
                                <span asp-validation-for="CategoryId" class="text-sm text-red-400 mt-2 block font-medium"></span>
                            </div>

                            <div class="pt-8">
                                <button type="submit" class="w-full flex justify-center items-center py-4 bg-blue-600 hover:bg-blue-500 text-white font-black text-lg rounded-xl shadow-[0_0_20px_rgba(37,99,235,0.4)] hover:shadow-[0_0_30px_rgba(37,99,235,0.6)] hover:-translate-y-1 transition-all duration-200 active:scale-95">
                                    <i class="bi bi-plus-circle mr-2"></i> Create Product
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                @section Scripts {
                    <partial name="_ValidationScriptsPartial" />
                }