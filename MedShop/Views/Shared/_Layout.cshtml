@using static MedShop.Core.Constants.User.AdminConstants
<!DOCTYPE html>
<html lang="en" class="overflow-y-scroll">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MedShop</title>
    <link rel="stylesheet" href="~/lib/toastr/toastr.min.css" />
    <link rel="stylesheet" href="~/css/tailwind.output.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.2/font/bootstrap-icons.css">
</head>
<body class="bg-slate-800 text-slate-200 font-sans antialiased min-h-screen flex flex-col">
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <partial name="_UserMessages" />

    <header class="bg-slate-950 border-b border-slate-800 text-slate-200 sticky top-0 z-50 shadow-md">
        <div class="container mx-auto px-4 py-3 flex items-center justify-between gap-4">
            <div class="flex-shrink-0">
                @if (User.Identity?.IsAuthenticated == true && User.IsInRole(AdminRoleName))
                {
                    <a class="flex items-center gap-2 text-xl font-bold text-white hover:text-blue-400 transition"
                           asp-area="Admin" asp-controller="Home" asp-action="Index">
                        <img src="https://content.presentermedia.com/files/clipart/00001000/1783/blue_medical_symbol_pc_800_wht.jpg" alt="Logo" class="w-8 h-8 rounded-full">
                        <span class="whitespace-nowrap">MedShop Admin</span>
                    </a>
                }
                else
                {
                    <a class="flex items-center gap-2 text-xl font-bold text-white hover:text-blue-400 transition"
                           asp-area="" asp-controller="Home" asp-action="Index">
                        <img src="https://content.presentermedia.com/files/clipart/00001000/1783/blue_medical_symbol_pc_800_wht.jpg" alt="Logo" class="w-8 h-8 rounded-full">
                        <span class="whitespace-nowrap">MedShop</span>
                    </a>
                }
            </div>

            <nav class="flex items-center gap-4 md:gap-6 font-medium text-xs md:text-sm overflow-x-auto no-scrollbar">
                <a class="hover:text-blue-400 transition flex items-center gap-1 md:gap-2 whitespace-nowrap" asp-area="" asp-controller="Product" asp-action="All">
                    <i class="bi bi-shop"></i> Storefront
                </a>

                @* FIXED: Swapped "Admin" for AdminRoleName constant *@
                @if (User.Identity?.IsAuthenticated == true && User.IsInRole(AdminRoleName))
                {
                    <span class="text-slate-800 font-thin hidden sm:inline">|</span>
                    <a class="text-blue-400 hover:text-blue-300 transition flex items-center gap-1 md:gap-2 whitespace-nowrap" asp-area="Admin" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-speedometer2"></i> Dashboard
                    </a>
                    <a class="hover:text-blue-400 transition flex items-center gap-1 md:gap-2 whitespace-nowrap" asp-area="Admin" asp-controller="User" asp-action="All">
                        <i class="bi bi-people"></i> Users
                    </a>
                    <a class="hover:text-blue-400 transition flex items-center gap-1 md:gap-2 whitespace-nowrap" asp-area="Admin" asp-controller="Order" asp-action="All">
                        <i class="bi bi-receipt"></i> Orders
                    </a>
                }
            </nav>

            <div class="flex-shrink-0">
                <div class="flex items-center gap-2 md:gap-4">
                    @await Component.InvokeAsync("ShoppingCartSummary")
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </div>
    </header>

    <div class="flex-grow w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="bg-slate-950 border-t border-slate-800 py-6 mt-auto">
        <div class="container mx-auto text-center text-sm text-slate-500">
            @{
                // FIXED: Swapped "Admin" for AdminRoleName constant
                var brandLabel = (User.Identity?.IsAuthenticated == true && User.IsInRole(AdminRoleName))
                                 ? "MedShop Administrator"
                                 : "MedShop";
            }
        
            &copy; @DateTime.Now.Year @brandLabel -
            <span id="footer-time" class="font-mono text-slate-400"></span>
        </div>

        <script>
                    (function() {
                        const timeSpan = document.getElementById("footer-time");
                        const updateTime = () => {
                            timeSpan.textContent = new Date().toLocaleTimeString();
                        };
                        updateTime();
                        setInterval(updateTime, 1000);
                    })();
        </script>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/lib/toastr/toastr.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>