@model MedShop.Core.Models.Product.ProductServiceModel
@using System.Security.Claims
@using static MedShop.Core.Constants.User.AdminConstants

@{
    ViewBag.Title = "Product Details";
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var isOwnerOrAdmin = User.Identity?.IsAuthenticated == true && (Model.SellerId == currentUserId || User.IsInRole(AdminRoleName));
}

<div class="max-w-6xl mx-auto py-8 px-4">
    <div class="flex flex-col lg:flex-row gap-12 bg-slate-900 rounded-3xl p-8 border border-slate-700 shadow-2xl relative overflow-hidden">
        
        <div class="absolute -top-24 -right-24 w-64 h-64 bg-blue-600/10 rounded-full blur-3xl"></div>

        <div class="lg:w-1/2 flex items-center justify-center bg-slate-800/30 rounded-2xl border border-slate-800 p-6">
            <img class="max-h-[500px] w-auto object-contain rounded-lg shadow-2xl transition-transform duration-500 hover:scale-105"
                 src="@Model.ImageUrl" alt="@Model.ProductName">
        </div>

        <div class="lg:w-1/2 flex flex-col">
            <div class="mb-6">
                <span class="px-3 py-1 bg-blue-600/20 text-blue-400 text-xs font-bold uppercase tracking-wider rounded-full border border-blue-600/30">
                    @Model.Category
                </span>
                <h2 class="text-4xl font-black text-white mt-4 mb-2 capitalize">@Model.ProductName</h2>
                <p class="text-slate-400 text-lg leading-relaxed">@Model.Description</p>
            </div>

            <div class="grid grid-cols-2 gap-6 py-6 border-y border-slate-800 my-4">
                <div>
                    <span class="text-slate-500 text-xs uppercase font-bold tracking-widest block mb-1">Seller</span>
                    <span class="text-white font-medium flex items-center gap-2">
                        <i class="bi bi-person-badge text-blue-400"></i> @Model.Seller
                    </span>
                </div>
                <div>
                    <span class="text-slate-500 text-xs uppercase font-bold tracking-widest block mb-1">Stock Availability</span>
                    <span class="text-white font-medium flex items-center gap-2">
                        <i class="bi bi-box-seam text-blue-400"></i> @Model.Quantity units
                    </span>
                </div>
            </div>

            <div class="mt-auto pt-6 flex flex-col gap-6">
                <div class="flex items-baseline gap-4">
                    <span class="text-4xl font-black text-emerald-400">$@Model.Price.ToString("F2")</span>
                    <span class="text-slate-500 text-sm italic">Includes standard medical handling fees</span>
                </div>

                <div class="flex flex-col sm:flex-row gap-4">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a asp-controller="ShoppingCart" asp-action="AddItemToShoppingCart" asp-route-id="@Model.Id"
                               class="flex-[2] flex justify-center items-center gap-3 px-8 py-4 bg-emerald-600 hover:bg-emerald-500 text-white font-bold rounded-2xl shadow-[0_0_20px_rgba(16,185,129,0.3)] transition-all active:scale-95">
                            <i class="bi bi-cart-plus-fill text-xl"></i> Add to Shopping Cart
                        </a>
                    }

                    @if (isOwnerOrAdmin)
                    {
                        <div class="flex flex-1 gap-2">
                            <a asp-controller="Product" asp-action="Edit" asp-route-id="@Model.Id" asp-route-information="@Model.GetInformation()"
                                   class="flex-1 flex justify-center items-center bg-amber-600/20 text-amber-400 border border-amber-600/30 hover:bg-amber-600 hover:text-white rounded-2xl transition-all active:scale-95">
                                <i class="bi bi-pencil-square"></i>
                            </a>
                            <a asp-controller="Product" asp-action="Delete" asp-route-id="@Model.Id" asp-route-information="@Model.GetInformation()"
                                   class="flex-1 flex justify-center items-center bg-red-600/20 text-red-400 border border-red-600/30 hover:bg-red-600 hover:text-white rounded-2xl transition-all active:scale-95">
                                <i class="bi bi-trash"></i>
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>