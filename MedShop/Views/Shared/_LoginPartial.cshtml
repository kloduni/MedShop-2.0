@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Mvc.TagHelpers
@using MedShop.Infrastructure.Data.Models
@inject SignInManager<User> SignInManager
@inject UserManager<User> UserManager

<ul class="flex items-center gap-4">
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="flex items-center gap-3">
            <a class="text-sm font-medium text-slate-300 hover:text-white transition" asp-area="" asp-controller="User" asp-action="Manage" title="Manage">
                Hello, <span class="text-blue-400">@User.Identity?.Name</span>!
            </a>
            <span class="text-slate-700">|</span>
            <form class="inline" asp-controller="User" asp-action="Logout" asp-route-id="@UserManager.GetUserId(User)">
                <button type="submit" class="text-sm font-medium text-slate-300 hover:text-red-400 transition-colors">Logout</button>
            </form>
        </li>
    }
    else
    {
        <li class="flex items-center gap-4">
            <a class="text-sm font-medium text-slate-300 hover:text-blue-400 transition-colors" asp-area="" asp-controller="User" asp-action="Register">Register</a>
            <a class="text-sm font-medium text-slate-300 hover:text-blue-400 transition-colors" asp-area="" asp-controller="User" asp-action="Login">Login</a>
        </li>
    }
</ul>