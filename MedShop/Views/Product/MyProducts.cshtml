@model IEnumerable<MedShop.Core.Models.Product.ProductServiceModel>

@{
    ViewBag.Title = "My Products";
}

<div class="py-8 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-8 flex flex-col md:flex-row md:items-end justify-between gap-6">
        <div>
            <h1 class="text-4xl font-black text-white tracking-tight flex items-center gap-3">
                <i class="bi bi-shop-window text-blue-500"></i> @ViewBag.Title
            </h1>
            <p class="mt-2 text-lg text-slate-400">Manage your active medical supply listings and inventory.</p>
        </div>
        
        <a asp-controller="Product" asp-action="Add" class="inline-flex justify-center items-center gap-2 py-3 px-6 bg-blue-600 hover:bg-blue-500 text-white font-bold rounded-xl shadow-[0_0_15px_rgba(37,99,235,0.4)] hover:shadow-[0_0_25px_rgba(37,99,235,0.6)] hover:-translate-y-1 transition-all duration-200 active:scale-95 shrink-0">
            <i class="bi bi-plus-circle-fill text-lg"></i> List New Product
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="flex flex-col items-center justify-center py-20 px-4 bg-slate-900 rounded-2xl border border-slate-700/50 shadow-xl">
            <div class="h-24 w-24 bg-slate-800 rounded-full flex items-center justify-center mb-6 shadow-inner border border-slate-700">
                <i class="bi bi-tags text-5xl text-slate-500"></i>
            </div>

            <h2 class="text-2xl font-bold text-white mb-2">No Products Listed</h2>
            <p class="text-slate-400 text-center max-w-md mb-8 text-lg">
                You haven't added any products to the catalog yet. Start selling your medical supplies today.
            </p>
            
            <a asp-controller="Product" asp-action="Add" class="inline-flex items-center px-6 py-3 bg-blue-600 text-white font-bold rounded-xl transition-all hover:bg-blue-500 hover:-translate-y-1 hover:shadow-[0_0_20px_rgba(37,99,235,0.5)] active:scale-95">
                <i class="bi bi-plus-lg mr-2"></i> Create Your First Listing
            </a>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
            @foreach (var product in Model)
            {
                <partial name="_ProductPartial" model="@product" />
            }
        </div>
    }
</div>