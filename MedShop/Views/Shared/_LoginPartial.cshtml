@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Mvc.TagHelpers
@using MedShop.Core.Data.Models
@using MedShop.Core.Cart
@inject SignInManager<User> SignInManager
@inject UserManager<User> UserManager
@inject ShoppingCart ShoppingCartService

<ul class="flex items-center gap-3 lg:gap-4">
    @if (SignInManager.IsSignedIn(User))
    {
        var currentCartItems = ShoppingCartService.GetShoppingCartItems();
        int initialCartCount = currentCartItems?.Sum(i => i.Amount) ?? 0;

        <li class="flex items-center gap-3 flex-wrap justify-end">
            <a class="text-sm font-medium text-slate-300 hover:text-blue-400 transition-colors flex items-center gap-1.5"
                   asp-area="" asp-controller="Product" asp-action="Add">
                <i class="bi bi-plus-circle"></i> <span class="hidden xl:inline">Sell</span>
            </a>

            <span class="text-slate-700">|</span>

            <a class="text-sm font-medium text-slate-300 hover:text-blue-400 transition-colors flex items-center gap-1.5"
                   asp-area="" asp-controller="Product" asp-action="MyProducts">
                <i class="bi bi-shop"></i> <span class="hidden xl:inline">My Products</span>
            </a>

            <span class="text-slate-700">|</span>

            <a class="text-sm font-medium text-slate-300 hover:text-pink-400 transition-colors flex items-center gap-1.5"
                   asp-area="" asp-controller="Wishlist" asp-action="Wishlist">
                <i class="bi bi-heart-fill text-pink-500"></i> <span class="hidden xl:inline">Wishlist</span>
            </a>

            <span class="text-slate-700">|</span>

            <a class="text-sm font-medium text-slate-300 hover:text-emerald-400 transition-colors flex items-center gap-1.5 relative mr-2"
                   asp-area="" asp-controller="ShoppingCart" asp-action="ShoppingCart">
                <i class="bi bi-cart3 text-lg"></i> <span class="hidden xl:inline">Cart</span>
                <span id="cart-badge-count" class="absolute -top-2 -right-3 bg-red-500 text-white text-[10px] font-bold px-1.5 py-0.5 rounded-full @(initialCartCount > 0 ? "" : "hidden")">@initialCartCount</span>
            </a>

            <span class="text-slate-700">|</span>

            <a class="text-sm font-medium text-slate-300 hover:text-emerald-400 transition-colors flex items-center gap-1.5"
                   asp-area="" asp-controller="Order" asp-action="All">
                <i class="bi bi-receipt"></i> <span class="hidden xl:inline">My Orders</span>
            </a>

            <span class="text-slate-700">|</span>

            <a class="text-sm font-medium text-slate-300 hover:text-blue-400 transition-colors flex items-center gap-1.5"
                   asp-area="" asp-controller="User" asp-action="Manage" title="Manage Profile">
                <i class="bi bi-person-circle"></i> <span class="hidden lg:inline">@User.Identity?.Name</span>
            </a>

            <span class="text-slate-700">|</span>

            <form class="inline m-0 p-0" asp-area="" asp-controller="User" asp-action="Logout" asp-route-id="@UserManager.GetUserId(User)">
                <button type="submit" class="text-sm font-medium text-slate-300 hover:text-red-400 transition-colors flex items-center gap-1.5">
                    <i class="bi bi-box-arrow-right"></i> <span class="hidden lg:inline">Logout</span>
                </button>
            </form>
        </li>
    }
    else
    {
        <li class="flex items-center gap-4">
            <a class="text-sm font-medium text-slate-300 hover:text-blue-400 transition-colors"
                   asp-area="" asp-controller="User" asp-action="Register">
                Register
            </a>
            <a class="px-4 py-1.5 bg-blue-600 hover:bg-blue-500 text-white text-sm font-bold rounded-lg transition-all shadow-[0_0_10px_rgba(37,99,235,0.3)] hover:shadow-[0_0_15px_rgba(37,99,235,0.5)]"
                   asp-area="" asp-controller="User" asp-action="Login">
                Login
            </a>
        </li>
    }
</ul>