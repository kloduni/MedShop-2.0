@{
    ViewData["Title"] = "Order Complete";
    var productId = ViewBag.ProductId as int?;
    var information = ViewBag.Information as string;
}

<div class="max-w-2xl mx-auto mt-16 px-4 sm:px-6">
    <div class="bg-slate-900 rounded-2xl shadow-xl border border-emerald-500/30 overflow-hidden text-center p-10 relative">
        
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-32 h-32 bg-emerald-500/20 blur-3xl rounded-full pointer-events-none"></div>

        <div class="relative z-10">
            <div class="w-20 h-20 bg-emerald-500/10 text-emerald-400 rounded-full flex items-center justify-center mx-auto mb-6 border border-emerald-500/20 shadow-[0_0_30px_rgba(16,185,129,0.2)]">
                <i class="bi bi-check-lg text-4xl font-bold"></i>
            </div>
            
            <h2 class="text-3xl font-bold text-white mb-4">Order Completed Successfully!</h2>
            <p class="text-slate-400 text-lg mb-8">Your payment has been processed and your items are confirmed.</p>
            
            <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
                @if (productId.HasValue && !string.IsNullOrEmpty(information))
                {
                    <a asp-controller="Product" asp-action="Details"
                           asp-route-id="@productId"
                           asp-route-information="@information"
                           class="w-full sm:w-auto px-6 py-3 bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-bold rounded-xl transition-all active:scale-95 shadow-[0_0_15px_rgba(79,70,229,0.4)]">
                        <i class="bi bi-chat-square-text mr-2"></i> Review Product
                    </a>
                }

                <a asp-controller="Order" asp-action="All"
                       class="w-full sm:w-auto px-6 py-3 bg-transparent border border-slate-600 hover:bg-slate-800 text-slate-300 hover:text-white text-sm font-bold rounded-xl transition-all">
                    View My Orders
                </a>
                
                <a asp-controller="Product" asp-action="All"
                       class="w-full sm:w-auto px-6 py-3 bg-blue-600 hover:bg-blue-500 text-white text-sm font-bold rounded-xl transition-all active:scale-95 shadow-[0_0_15px_rgba(37,99,235,0.4)]">
                    Continue Shopping
                </a>
            </div>
        </div>
    </div>
</div>