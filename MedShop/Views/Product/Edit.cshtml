@model ProductBaseModel

@{
    ViewData["Title"] = "Edit Product";
}

<div class="max-w-2xl mx-auto bg-slate-900 p-8 rounded-2xl shadow-xl border border-slate-700 text-slate-200">
    <h2 class="text-3xl font-bold text-white mb-2 text-center">@ViewData["Title"]</h2>
    <p class="text-center text-slate-400 mb-8 text-sm">Update the product specifications and availability below.</p>
    
    <form method="post" class="space-y-5">
        @* CRITICAL: The Hidden ID ensures the controller knows WHICH product to update *@
        <input type="hidden" asp-for="@Model.Id" />
        
        @* Product Name *@
        <div>
            <label asp-for="ProductName" class="block text-sm font-medium text-slate-300 mb-1">Product Name</label>
            <input asp-for="ProductName" class="w-full px-4 py-2 bg-slate-800 border border-slate-700 rounded-lg text-white placeholder-slate-500 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition-all">
                <span asp-validation-for="ProductName" class="text-xs text-red-400 mt-1 block"></span>
            </div>
    
            @* Price & Quantity Grid *@
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label asp-for="Price" class="block text-sm font-medium text-slate-300 mb-1"></label>
                    <div class="relative">
                        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-500">$</span>
                        <input asp-for="Price" class="w-full pl-7 pr-4 py-2 bg-slate-800 border border-slate-700 rounded-lg text-white focus:ring-2 focus:ring-blue-500 outline-none transition-all">
                        </div>
                        <span asp-validation-for="Price" class="text-xs text-red-400 mt-1 block"></span>
                    </div>
    
                    <div>
                        <label asp-for="Quantity" class="block text-sm font-medium text-slate-300 mb-1"></label>
                        <input asp-for="Quantity" class="w-full px-4 py-2 bg-slate-800 border border-slate-700 rounded-lg text-white focus:ring-2 focus:ring-blue-500 outline-none transition-all">
                            <span asp-validation-for="Quantity" class="text-xs text-red-400 mt-1 block"></span>
                        </div>
                    </div>

                    @* Description *@
                    <div>
                        <label asp-for="Description" class="block text-sm font-medium text-slate-300 mb-1"></label>
                        <textarea asp-for="Description" rows="4" class="w-full px-4 py-2 bg-slate-800 border border-slate-700 rounded-lg text-white placeholder-slate-500 focus:ring-2 focus:ring-blue-500 outline-none transition-all"></textarea>
                        <span asp-validation-for="Description" class="text-xs text-red-400 mt-1 block"></span>
                    </div>

                    @* Image URL *@
                    <div>
                        <label asp-for="ImageUrl" class="block text-sm font-medium text-slate-300 mb-1">Image URL</label>
                        <input asp-for="ImageUrl" class="w-full px-4 py-2 bg-slate-800 border border-slate-700 rounded-lg text-white placeholder-slate-500 focus:ring-2 focus:ring-blue-500 outline-none transition-all">
                            <span asp-validation-for="ImageUrl" class="text-xs text-red-400 mt-1 block"></span>
                        </div>

                        @* Category Selection *@
                        <div>
                            <label asp-for="CategoryId" class="block text-sm font-medium text-slate-300 mb-1">Category</label>
                            <select asp-for="CategoryId" class="w-full px-4 py-2 bg-slate-800 border border-slate-700 rounded-lg text-white focus:ring-2 focus:ring-blue-500 outline-none transition-all cursor-pointer">
                                @foreach (var category in Model.ProductCategories)
                                {
                                    <option value="@category.Id">@category.Name</option>
                                }
                            </select>
                            <span asp-validation-for="CategoryId" class="text-xs text-red-400 mt-1 block"></span>
                        </div>

                        @* Submit Button *@
                        <div class="text-center pt-6">
                            <button type="submit" class="w-full md:w-auto px-10 py-3 bg-blue-600 hover:bg-blue-500 text-white font-bold rounded-xl shadow-[0_0_20px_rgba(37,99,235,0.3)] transition-all active:scale-95">
                                <i class="bi bi-cloud-arrow-up mr-2"></i> Save Changes
                            </button>
                            <div class="mt-4">
                                <a asp-action="All" class="text-slate-500 hover:text-slate-300 text-sm transition-colors">
                                    Cancel and Return to Catalog
                                </a>
                            </div>
                        </div>
                    </form>
                </div>

                @section Scripts {
                    <partial name="_ValidationScriptsPartial" />
                }