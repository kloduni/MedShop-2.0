@model AllProductsQueryModel

@{
    ViewBag.Title = "Deleted Products";
}

<div class="max-w-7xl mx-auto py-8">
    <div class="mb-8 text-center md:text-left">
        <h2 class="text-3xl font-black text-white tracking-tight flex items-center justify-center md:justify-start gap-3">
            <i class="bi bi-trash3 text-red-500"></i> @ViewBag.Title
        </h2>
        <p class="mt-2 text-lg text-slate-400">Manage and restore products that have been removed from the storefront.</p>
    </div>

    <div class="bg-slate-900 rounded-2xl shadow-xl border border-slate-700/50 mb-8 relative overflow-hidden p-6">
        <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-red-600 to-amber-500 opacity-50"></div>

        <form method="get" class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5 gap-6 items-end relative z-10">
            <div>
                <label asp-for="Category" class="block text-sm font-bold text-slate-300 mb-2"></label>
                <div class="relative">
                    <select asp-for="Category" class="w-full bg-slate-800 border border-slate-600 hover:border-red-500/50 hover:bg-slate-700/50 text-white rounded-xl appearance-none focus:ring-2 focus:ring-red-500 focus:border-red-500 py-3 px-4 pr-10 transition-all outline-none cursor-pointer">
                        <option value="">All Categories</option>
                        @foreach (var category in Model.Categories)
                        {
                            <option value="@category">@category</option>
                        }
                    </select>
                    <i class="bi bi-chevron-down absolute right-4 top-1/2 transform -translate-y-1/2 text-slate-400 pointer-events-none"></i>
                </div>
            </div>

            <div>
                <label asp-for="SearchTerm" class="block text-sm font-bold text-slate-300 mb-2">Keyword</label>
                <div class="relative group">
                    <i class="bi bi-search absolute left-4 top-1/2 transform -translate-y-1/2 text-slate-400 group-focus-within:text-red-500 transition-colors"></i>
                    <input asp-for="SearchTerm" class="w-full bg-slate-800 border border-slate-600 hover:border-red-500/50 hover:bg-slate-700/50 text-white rounded-xl focus:ring-2 focus:ring-red-500 focus:border-red-500 py-3 pl-11 pr-4 placeholder-slate-500 transition-all outline-none" placeholder="Search..." />
                </div>
            </div>

            <div>
                <label asp-for="Sorting" class="block text-sm font-bold text-slate-300 mb-2"></label>
                <div class="relative">
                    <select asp-for="Sorting" class="w-full bg-slate-800 border border-slate-600 hover:border-red-500/50 hover:bg-slate-700/50 text-white rounded-xl appearance-none focus:ring-2 focus:ring-red-500 focus:border-red-500 py-3 px-4 pr-10 transition-all outline-none cursor-pointer">
                        <option value="0">Newest Deleted</option>
                        <option value="1">Lowest Price</option>
                    </select>
                    <i class="bi bi-chevron-down absolute right-4 top-1/2 transform -translate-y-1/2 text-slate-400 pointer-events-none"></i>
                </div>
            </div>

            <div>
                <label asp-for="ProductsPerPage" class="block text-sm font-bold text-slate-300 mb-2">Per Page</label>
                <div class="relative">
                    <select asp-for="ProductsPerPage" class="w-full bg-slate-800 border border-slate-600 hover:border-red-500/50 hover:bg-slate-700/50 text-white rounded-xl appearance-none focus:ring-2 focus:ring-red-500 focus:border-red-500 py-3 px-4 pr-10 transition-all outline-none cursor-pointer">
                        <option value="4">4 Items</option>
                        <option value="6">6 Items</option>
                        <option value="9">9 Items (Default)</option>
                        <option value="12">12 Items</option>
                        <option value="16">16 Items</option>
                    </select>
                    <i class="bi bi-chevron-down absolute right-4 top-1/2 transform -translate-y-1/2 text-slate-400 pointer-events-none"></i>
                </div>
            </div>

            <div>
                <button type="submit" class="w-full flex justify-center items-center py-3 px-4 rounded-xl text-sm font-bold text-white bg-slate-700 hover:bg-slate-600 shadow-[0_0_15px_rgba(0,0,0,0.4)] hover:shadow-[0_0_20px_rgba(255,255,255,0.1)] hover:-translate-y-1 transition-all duration-200 active:scale-95 border border-slate-600 hover:border-slate-500">
                    <i class="bi bi-search text-lg mr-2"></i> Search
                </button>
            </div>
        </form>
    </div>

    @if (!Model.Products.Any())
    {
        <div class="flex flex-col items-center justify-center py-20 px-4 bg-slate-900 rounded-2xl border border-slate-700/50 shadow-xl">
            <div class="h-24 w-24 bg-slate-800 rounded-full flex items-center justify-center mb-6 shadow-inner border border-slate-700">
                <i class="bi bi-inbox text-5xl text-slate-500"></i>
            </div>

            <h2 class="text-2xl font-bold text-white mb-2">No Products Found</h2>
        
            @if (!string.IsNullOrEmpty(Model.SearchTerm) || !string.IsNullOrEmpty(Model.Category))
            {
                <p class="text-slate-400 text-center max-w-md mb-8 text-lg">
                    No deleted products match your current filters. Try adjusting your search criteria.
                </p>
                <a asp-action="DeletedProducts" asp-route-searchTerm="" asp-route-category=""
                       class="inline-flex items-center px-6 py-3 bg-slate-800 text-white font-bold rounded-xl border border-slate-700 hover:bg-slate-700 hover:-translate-y-1 transition-all active:scale-95 shadow-lg">
                    <i class="bi bi-arrow-counterclockwise mr-2"></i> Clear Filters
                </a>
            }
            else
            {
                <p class="text-slate-400 text-center max-w-md mb-8 text-lg">
                    Your recycle bin is completely empty. When you delete a product, it will show up here.
                </p>
                <a asp-area="Admin" asp-controller="Home" asp-action="Index"
                       class="inline-flex items-center px-6 py-3 bg-blue-600 text-white font-bold rounded-xl transition-all hover:bg-blue-500 hover:-translate-y-1 hover:shadow-[0_0_20px_rgba(37,99,235,0.5)] active:scale-95">
                    <i class="bi bi-arrow-left mr-2"></i> Back to Dashboard
                </a>
            }
        </div>
    }
    else
    {
        var previousPage = Model.CurrentPage - 1;
        if (previousPage < 1) { previousPage = 1; }
        
        var maxPage = Math.Ceiling((double)Model.TotalProductsCount / Model.ProductsPerPage);
        var shouldButtonBeDisabled = Model.CurrentPage == (int)maxPage;

        <div class="flex justify-between items-center mb-8 bg-slate-900 px-6 py-4 rounded-xl border border-slate-700/50 shadow-md">
            <a class="px-5 py-2.5 bg-slate-800 border border-slate-600 rounded-lg text-slate-300 font-bold hover:bg-slate-700 hover:text-white transition-all hover:-translate-y-0.5 shadow-sm @(Model.CurrentPage == 1 ? "opacity-40 pointer-events-none" : "")"
                   asp-area="Admin" asp-controller="Product" asp-action="DeletedProducts"
                   asp-route-currentPage="@previousPage" asp-route-category="@Model.Category"
                   asp-route-searchTerm="@Model.SearchTerm" asp-route-sorting="@((int)Model.Sorting)"
                   asp-route-productsPerPage="@Model.ProductsPerPage">
                <i class="bi bi-chevron-left mr-1"></i> Previous
            </a>

            <div class="text-sm text-slate-400 font-medium">
                Page <span class="text-white font-bold mx-1">@Model.CurrentPage</span> of <span class="text-white font-bold mx-1">@(maxPage == 0 ? 1 : maxPage)</span>
            </div>

            <a class="px-5 py-2.5 bg-slate-800 border border-slate-600 rounded-lg text-slate-300 font-bold hover:bg-slate-700 hover:text-white transition-all hover:-translate-y-0.5 shadow-sm @(shouldButtonBeDisabled ? "opacity-40 pointer-events-none" : "")"
                   asp-area="Admin" asp-controller="Product" asp-action="DeletedProducts"
                   asp-route-currentPage="@(Model.CurrentPage + 1)" asp-route-category="@Model.Category"
                   asp-route-searchTerm="@Model.SearchTerm" asp-route-sorting="@((int)Model.Sorting)"
                   asp-route-productsPerPage="@Model.ProductsPerPage">
                Next <i class="bi bi-chevron-right ml-1"></i>
            </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8">
            @foreach (var product in Model.Products)
            {
                <partial name="_AdminProductPartial" model="@product" />
            }
        </div>
    }
</div>