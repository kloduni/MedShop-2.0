@{
    ViewData["Title"] = "Admin Home Page";
}

<div class="text-center mb-10">
    <h1 class="text-4xl font-extrabold text-white tracking-tight">Welcome Admin!</h1>
    <p class="text-slate-400 mt-2 text-lg">System Supervision & Management</p>
</div>

<div class="flex flex-wrap justify-center gap-4 mb-12">
    <a asp-area="Admin" asp-controller="User" asp-action="All"
           class="inline-flex items-center px-6 py-3 bg-blue-600 text-white font-medium rounded-lg
        transition-all duration-200 ease-in-out hover:bg-blue-500 hover:shadow-[0_0_15px_rgba(59,130,246,0.5)] active:scale-95">
        <i class="bi bi-people-fill mr-2"></i> Manage Users
    </a>
    
    <a asp-area="Admin" asp-controller="Product" asp-action="DeletedProducts"
           class="inline-flex items-center px-6 py-3 bg-red-600 text-white font-medium rounded-lg
        transition-all duration-200 ease-in-out hover:bg-red-500 hover:shadow-[0_0_15px_rgba(239,68,68,0.5)] active:scale-95">
        <i class="bi bi-trash-fill mr-2"></i> Deleted Products
    </a>

    <a asp-area="Admin" asp-controller="Product" asp-action="HiddenProducts"
           class="inline-flex items-center px-6 py-3 bg-purple-600 text-white font-medium rounded-lg
        transition-all duration-200 ease-in-out hover:bg-purple-500 hover:shadow-[0_0_15px_rgba(168,85,247,0.5)] active:scale-95">
        <i class="bi bi-eye-slash-fill mr-2"></i> Hidden Products
    </a>
</div>

<div class="text-center mb-8">
    <button id="statistics-button"
            class="inline-flex items-center px-6 py-2 bg-slate-800 text-slate-200 border border-slate-700 font-medium rounded-lg
        transition-all duration-200 ease-in-out hover:bg-slate-700 hover:text-white hover:shadow-[0_0_15px_rgba(148,163,184,0.3)] active:scale-95">
        <i class="bi bi-bar-chart-fill mr-2"></i> Load Live Statistics
    </button>
</div>

<div id="userStatistics" class="hidden grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
    <div class="bg-slate-900 p-6 rounded-xl shadow-lg border border-slate-700 text-center transition hover:-translate-y-1 hover:shadow-[0_10px_20px_rgba(0,0,0,0.4)] duration-300">
        <h3 class="text-slate-400 text-sm font-semibold uppercase tracking-wider">Total Users</h3>
        <p id="total-users" class="text-4xl font-bold text-blue-400 mt-3">-</p>
    </div>
    
    <div class="bg-slate-900 p-6 rounded-xl shadow-lg border border-slate-700 text-center transition hover:-translate-y-1 hover:shadow-[0_10px_20px_rgba(0,0,0,0.4)] duration-300">
        <h3 class="text-slate-400 text-sm font-semibold uppercase tracking-wider">Active Users</h3>
        <p id="active-users" class="text-4xl font-bold text-green-400 mt-3">-</p>
    </div>
    
    <div class="bg-slate-900 p-6 rounded-xl shadow-lg border border-slate-700 text-center transition hover:-translate-y-1 hover:shadow-[0_10px_20px_rgba(0,0,0,0.4)] duration-300">
        <h3 class="text-slate-400 text-sm font-semibold uppercase tracking-wider">Total Products</h3>
        <p id="total-products" class="text-4xl font-bold text-indigo-400 mt-3">-</p>
    </div>
    
    <div class="bg-slate-900 p-6 rounded-xl shadow-lg border border-slate-700 text-center transition hover:-translate-y-1 hover:shadow-[0_10px_20px_rgba(0,0,0,0.4)] duration-300">
        <h3 class="text-slate-400 text-sm font-semibold uppercase tracking-wider">Active Products</h3>
        <p id="active-products" class="text-4xl font-bold text-teal-400 mt-3">-</p>
    </div>
</div>

<div id="chartContainer" class="hidden mt-8 max-w-2xl mx-auto bg-slate-900 p-6 rounded-xl shadow-lg border border-slate-700">
    <h3 class="text-slate-300 text-lg font-bold mb-4 text-center">Active Products by Category</h3>
    <div class="relative h-64 w-full">
        <canvas id="categoryChart"></canvas>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        $('#statistics-button').on('click', ev => {
        const btnIcon = $(ev.currentTarget).find('i');
        btnIcon.removeClass('bi-bar-chart-fill').addClass('bi-arrow-repeat animate-spin');

        $.get('https://localhost:7071/api/usersstatisticsapi', (data) => {
        $('#total-users').text(data.totalUsers);
        $('#active-users').text(data.activeUsers);
        $('#total-products').text(data.totalProducts);
        $('#active-products').text(data.activeProducts);
                
        $('#userStatistics').removeClass('hidden').hide().fadeIn(400);
        $('#statistics-button').fadeOut(300);
        }).fail(function() {
        btnIcon.removeClass('bi-arrow-repeat animate-spin').addClass('bi-exclamation-triangle-fill text-red-400');
        $('#statistics-button').text(' Failed to load data');
        });

        $.get('https://localhost:7071/api/usersstatisticsapi/categories', (chartData) => {
        $('#chartContainer').removeClass('hidden').hide().fadeIn(600);
                
        const labels = chartData.map(c => c.category);
        const counts = chartData.map(c => c.count);

        const ctx = document.getElementById('categoryChart').getContext('2d');
        new Chart(ctx, {
        type: 'doughnut',
        data: {
        labels: labels,
        datasets: [{
        data: counts,
        backgroundColor: [
        '#3b82f6',
        '#10b981',
        '#f59e0b',
        '#8b5cf6',
        '#ef4444'
        ],
        borderColor: '#0f172a',
        borderWidth: 2
        }]
        },
        options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
        legend: {
        position: 'right',
        labels: { color: '#94a3b8' }
        }
        }
        }
        });
        });
        });
    </script>
}