@model AllProductsQueryModel

@{
    ViewBag.Title = "Deleted Products";
}

<h2 class="text-3xl font-bold text-center text-white mb-8">@ViewBag.Title</h2>

<div class="bg-slate-900 p-6 rounded-xl shadow-lg border border-slate-700 mb-8">
    <form method="get" class="grid grid-cols-1 md:grid-cols-4 gap-4 items-end">
        <div>
            <label asp-for="Category" class="block text-sm font-medium text-slate-300 mb-1"></label>
            <select asp-for="Category" class="w-full bg-slate-800 border-slate-600 text-white rounded-md focus:ring-blue-500 focus:border-blue-500 transition-colors">
                <option value="">All Categories</option>
                @foreach (var category in Model.Categories)
                {
                    <option value="@category">@category</option>
                }
            </select>
        </div>

        <div>
            <label asp-for="SearchTerm" class="block text-sm font-medium text-slate-300 mb-1">Keyword</label>
            <input asp-for="SearchTerm" class="w-full bg-slate-800 border-slate-600 text-white rounded-md focus:ring-blue-500 focus:border-blue-500 placeholder-slate-500 transition-colors" placeholder="...">
            </div>

            <div>
                <label asp-for="Sorting" class="block text-sm font-medium text-slate-300 mb-1"></label>
                <select asp-for="Sorting" class="w-full bg-slate-800 border-slate-600 text-white rounded-md focus:ring-blue-500 focus:border-blue-500 transition-colors">
                    <option value="0">Newest</option>
                    <option value="1">Lowest price</option>
                </select>
            </div>

            <div>
                <button type="submit" class="w-full bg-blue-600 text-white font-medium py-2 px-4 rounded-md transition-all duration-200 ease-in-out hover:bg-blue-500 hover:shadow-[0_0_15px_rgba(59,130,246,0.5)] active:scale-95">
                    <i class="bi bi-search mr-2"></i> Search
                </button>
            </div>
        </form>
    </div>

    @if (!Model.Products.Any())
    {
        <div class="flex flex-col items-center justify-center py-20 px-4 bg-slate-900 rounded-xl border border-slate-700 shadow-lg">
            <div class="h-24 w-24 bg-slate-800 rounded-full flex items-center justify-center mb-6 shadow-inner border border-slate-700">
                <i class="bi bi-inbox text-5xl text-slate-500"></i>
            </div>

            <h2 class="text-2xl font-bold text-white mb-2">No Products Found</h2>
        
            @if (!string.IsNullOrEmpty(Model.SearchTerm) || !string.IsNullOrEmpty(Model.Category))
            {
                <p class="text-slate-400 text-center max-w-md mb-8">
                    No deleted products match your current filters. Try adjusting your search criteria.
                </p>
                <a asp-action="DeletedProducts" asp-route-searchTerm="" asp-route-category=""
                       class="inline-flex items-center px-6 py-3 bg-slate-700 text-white font-medium rounded-lg transition hover:bg-slate-600 active:scale-95">
                    <i class="bi bi-arrow-counterclockwise mr-2"></i> Clear Filters
                </a>
            }
            else
            {
                <p class="text-slate-400 text-center max-w-md mb-8">
                    Your recycle bin is completely empty. When you delete a product, it will show up here.
                </p>
                <a asp-area="Admin" asp-controller="Home" asp-action="Index"
                       class="inline-flex items-center px-6 py-3 bg-blue-600 text-white font-medium rounded-lg transition-all hover:bg-blue-500 hover:shadow-[0_0_15px_rgba(59,130,246,0.5)] active:scale-95">
                    <i class="bi bi-arrow-left mr-2"></i> Back to Dashboard
                </a>
            }
        </div>
    }
    else
    {
        var previousPage = Model.CurrentPage - 1;
        if (previousPage < 1) { previousPage = 1; }
        var maxPage = Math.Ceiling((double)Model.TotalProductsCount / AllProductsQueryModel.ProductsPerPage);
        var shouldButtonBeDisabled = Model.CurrentPage == (int)maxPage;

        <div class="flex justify-between items-center mb-6">
            <a class="px-4 py-2 bg-slate-900 border border-slate-700 rounded-md text-slate-300 hover:bg-slate-800 hover:text-white transition-all @(Model.CurrentPage == 1 ? "opacity-30 pointer-events-none" : "")"
                   asp-area="Admin" asp-controller="Product" asp-action="DeletedProducts"
                   asp-route-currentPage="@previousPage" asp-route-category="@Model.Category"
                   asp-route-searchTerm="@Model.SearchTerm" asp-route-sorting="@((int)Model.Sorting)">
                <i class="bi bi-chevron-left"></i> Previous
            </a>

            <a class="px-4 py-2 bg-slate-900 border border-slate-700 rounded-md text-slate-300 hover:bg-slate-800 hover:text-white transition-all @(shouldButtonBeDisabled ? "opacity-30 pointer-events-none" : "")"
                   asp-area="Admin" asp-controller="Product" asp-action="DeletedProducts"
                   asp-route-currentPage="@(Model.CurrentPage + 1)" asp-route-category="@Model.Category"
                   asp-route-searchTerm="@Model.SearchTerm" asp-route-sorting="@((int)Model.Sorting)">
                Next <i class="bi bi-chevron-right"></i>
            </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var product in Model.Products)
            {
                <partial name="_AdminProductPartial" model="@product" />
            }
        </div>
    }